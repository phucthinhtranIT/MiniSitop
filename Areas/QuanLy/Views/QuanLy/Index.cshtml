                    <label><span>Tên chương trình</span><input name="Ten" placeholder="Khuyến mãi cuối tuần" maxlength="150" required></label>
                    <label><span>Mã áp dụng</span><input name="Ma" placeholder="CUOITUAN" maxlength="50" required></label>
                    <label><span>Phần trăm giảm</span><input name="PhanTramGiam" type="number" min="0" max="100" step="0.5" value="0"></label>
                    <label><span>Bắt đầu</span><input name="NgayBatDau" type="date" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")"></label>
                    <label><span>Kết thúc</span><input name="NgayKetThuc" type="date" value="@DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd")"></label>
                </div>
            </section>
        </div>
        <div class="product-modal-actions">
            <button class="btn-secondary" data-close-promo-modal type="button">Hủy</button>
            <button class="btn-primary" type="submit">Lưu khuyến mãi</button>
        </div>
    </form>
</div>

<aside id="invoicePanel" class="slide-panel translate-x-full">
    <div class="card-head"><div><p class="eyebrow">Invoice</p><h3 id="invoicePanelTitle">Chi tiết hóa đơn</h3></div><button class="btn-icon" data-close-panel type="button">×</button></div>
    <div id="invoicePanelBody">
        <div class="empty-state compact"><span>◇</span><h3>Chọn một hóa đơn</h3><p>Bấm “Xem chi tiết” ở từng dòng đơn hàng để mở thông tin đầy đủ.</p></div>
    </div>
</aside>

<aside id="customerPanel" class="slide-panel translate-x-full">
    <div class="card-head"><div><p class="eyebrow">Customer</p><h3 id="customerPanelTitle">Chi tiết khách hàng</h3></div><button class="btn-icon" data-close-customer-panel type="button">×</button></div>
    <div id="customerPanelBody">
        <div class="empty-state compact"><span>K</span><h3>Chọn khách hàng</h3><p>Bấm “Chi tiết” ở từng dòng khách hàng để xem hồ sơ đầy đủ.</p></div>
    </div>
</aside>

@foreach (var order in donHangs)
{
    <template id="invoice-template-@order.Id">
        <div class="space-y-4">
            <div class="alert-row info"><span>i</span><p>@OrderText(order.TrangThai), phương thức @HienThiThanhToan(order.PhuongThucThanhToan).</p></div>
            <div class="invoice-line">
                <strong>Khách hàng</strong>
                <span>@(order.KhachHang?.HoTen ?? "Khách lẻ")</span>
                <small>Nhân viên phụ trách: @(order.NhanVien?.HoTen ?? "Hệ thống Web") • @order.NgayDat.ToLocalTime().ToString("dd/MM/yyyy HH:mm", culture)</small>
            </div>
            <div class="invoice-line">
                <strong>Kênh: @(order.KenhBanHang == "Web" ? "Website" : "Tại quầy") | Giao hàng & thanh toán</strong>
                <span>@(string.IsNullOrWhiteSpace(order.DiaChiGiaoHang) ? "Tại quầy" : order.DiaChiGiaoHang)</span>
                <small>@(string.IsNullOrWhiteSpace(order.GhiChuThanhToan) ? "Chưa có ghi chú thanh toán." : order.GhiChuThanhToan)</small>
            </div>
            <div class="space-y-3">
                @foreach (var item in order.ChiTiet)
                {
                    <div class="invoice-line">
                        <strong>@(item.SanPham?.Ten ?? "Sản phẩm không xác định")</strong>
                        <small>@(item.SanPham?.Ma ?? "-") • @item.SoLuong x @Money(item.DonGia)</small>
                        <span>@Money(item.SoLuong * item.DonGia - item.TienGiam)</span>
                    </div>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(order.MaKhuyenMaiDaDung) || order.TienGiamKhuyenMai > 0 || order.DiemThuongSuDung > 0 || order.TienGiamDiem > 0)
            {
                <div class="invoice-line">
                    <strong>Ưu đãi đã dùng</strong>
                    @if (!string.IsNullOrWhiteSpace(order.MaKhuyenMaiDaDung))
                    {
                        <small>Mã giảm giá: @order.MaKhuyenMaiDaDung - @Money(order.TienGiamKhuyenMai)</small>
                    }
                    @if (order.DiemThuongSuDung > 0 || order.TienGiamDiem > 0)
                    {
                        <small>Điểm tích lũy: @order.DiemThuongSuDung điểm - @Money(order.TienGiamDiem)</small>
                    }
                </div>
            }
            @if (order.DiemThuongCong > 0)
            {
                <div class="alert-row info"><span>+</span><p>Đơn này cộng @order.DiemThuongCong.ToString("N0", culture) điểm tích lũy.</p></div>
            }
            <div class="invoice-total-row"><span>Tổng tiền</span><strong class="text-2xl text-blue-600 dark:text-sky-300">@Money(order.TongTien)</strong></div>
            @if (order.PhuongThucThanhToan == "ChuyenKhoan" && order.TrangThai == "DangXuLy")
            {
                <button class="btn-primary w-full opacity-50 cursor-not-allowed" type="button" disabled title="Vui lòng xác nhận thanh toán trước khi in hóa đơn" style="background-color: #94a3b8; border-color: #94a3b8;">Đang chờ xác thực SePAY</button>
            }
            else
            {
                <button class="btn-primary w-full" type="button" onclick="window.open('/NhanVien/InHoaDon?id=@order.Id', '_blank')">Xuất PDF / In hóa đơn</button>
            }
        </div>
    </template>
}

@foreach (var customer in khachHangs)
{
    var customerOrders = donHangs.Where(d => d.KhachHangId == customer.Id).OrderByDescending(d => d.NgayDat).ToList();
    <template id="customer-template-@customer.Id">
        <div class="space-y-4">
            <div class="customer-profile-head">
                <span>@customer.HoTen.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault()?.FirstOrDefault()</span>
                <div>
                    <strong>@customer.HoTen</strong>
                    <small>KH-@customer.Id.ToString("0000") • @(customer.KichHoat ? "Đang hoạt động" : "Ngừng")</small>
                </div>
            </div>
            <div class="grid gap-3 md:grid-cols-2">
                <div class="invoice-line"><strong>Số điện thoại</strong><span>@(customer.DienThoai ?? "-")</span></div>
                <div class="invoice-line"><strong>Email</strong><span>@(customer.Email ?? "-")</span></div>
                <div class="invoice-line"><strong>Điểm tích lũy</strong><span>@customer.DiemThuong.ToString("N0", culture) điểm</span></div>
                <div class="invoice-line"><strong>Tổng chi tiêu</strong><span>@Money(customerOrders.Sum(d => d.TongTien))</span></div>
            </div>
            <div class="invoice-line">
                <strong>Lịch sử mua hàng</strong>
                <small>@customerOrders.Count đơn hàng trong hệ thống</small>
            </div>
            <div class="space-y-3">
                @foreach (var order in customerOrders.Take(5))
                {
                    <div class="invoice-line">
                        <strong>HD-@order.Id.ToString("0000")</strong>
                        <small>@order.NgayDat.ToLocalTime().ToString("dd/MM/yyyy HH:mm", culture) • @OrderText(order.TrangThai)</small>
                        <span>@Money(order.TongTien)</span>
                    </div>
                }
                @if (!customerOrders.Any())
                {
                    <div class="empty-state compact"><span>◇</span><h3>Chưa có đơn hàng</h3><p>Khách hàng này chưa phát sinh đơn trong hệ thống.</p></div>
                }
            </div>
        </div>
    </template>
}

@section Scripts {
    <script>
        (() => {
            const pages = document.querySelectorAll("[data-page]");
            const links = document.querySelectorAll("[data-page-link]");
            const modal = document.getElementById("productModal");
            const panel = document.getElementById("invoicePanel");
            const customerPanel = document.getElementById("customerPanel");
            const productForm = document.getElementById("productForm");
            const productModalTitle = document.getElementById("productModalTitle");
            const productSubmitText = document.getElementById("productSubmitText");
            const productRows = document.querySelectorAll("[data-product-row]");
            const productSearch = document.querySelector("[data-product-search]");
            const productCategory = document.querySelector("[data-product-category]");
            const productStatus = document.querySelector("[data-product-status]");
            const productMaxPrice = document.querySelector("[data-product-max-price]");
            const createProductAction = "/QuanLy/CreateSanPham";
            const updateProductAction = "/QuanLy/UpdateSanPham";

            const setProductField = (name, value) => {
                const field = productForm?.querySelector(`[name="${name}"]`);
                if (!field) return;
                if (field.type === "checkbox") {
                    field.checked = value === true || value === "true";
                    return;
                }
                field.value = value ?? "";
            };

            const openCreateProduct = () => {
                productForm?.reset();
                if (productForm) productForm.action = createProductAction;
                if (productModalTitle) productModalTitle.textContent = "Thêm sản phẩm";
                if (productSubmitText) productSubmitText.textContent = "Lưu sản phẩm";
                setProductField("Id", "0");
                setProductField("GiaVon", "0");
                setProductField("GiaBan", "0");
                setProductField("TonKho", "0");
                setProductField("MucCanNhapLai", "10");
                setProductField("DonVi", "cái");
                setProductField("KichHoat", true);
                modal?.classList.remove("hidden");
            };

            const openEditProduct = (button) => {
                if (productForm) productForm.action = updateProductAction;
                if (productModalTitle) productModalTitle.textContent = "Sửa sản phẩm";
                if (productSubmitText) productSubmitText.textContent = "Cập nhật sản phẩm";
                setProductField("Id", button.dataset.id);
                setProductField("Ma", button.dataset.ma);
                setProductField("Ten", button.dataset.ten);
                setProductField("MoTa", button.dataset.mota);
                setProductField("HinhAnh", button.dataset.hinhanh);
                setProductField("DanhMucId", button.dataset.danhmucid);
                setProductField("NhaCungCapId", button.dataset.nhacungcapid);
                setProductField("GiaVon", button.dataset.giavon);
                setProductField("GiaBan", button.dataset.giaban);
                setProductField("DonVi", button.dataset.donvi);
                setProductField("TonKho", button.dataset.tonkho);
                setProductField("MucCanNhapLai", button.dataset.muccannhaplai);
                setProductField("KichHoat", button.dataset.kichhoat);
                modal?.classList.remove("hidden");
            };

            const showPage = (pageName) => {
                pages.forEach(page => page.classList.toggle("hidden", page.dataset.page !== pageName));
                links.forEach(link => link.classList.toggle("is-active", link.dataset.pageLink === pageName));
                const target = document.getElementById(pageName);
                if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
            };

            links.forEach(link => link.addEventListener("click", (event) => {
                event.preventDefault();
                history.replaceState(null, "", `#${link.dataset.pageLink}`);
                showPage(link.dataset.pageLink);
            }));

            document.querySelectorAll("[data-open-modal]").forEach(btn => btn.addEventListener("click", openCreateProduct));
            document.querySelectorAll("[data-edit-product]").forEach(btn => btn.addEventListener("click", () => openEditProduct(btn)));
            document.querySelectorAll("[data-close-modal]").forEach(btn => btn.addEventListener("click", () => modal?.classList.add("hidden")));
            modal?.addEventListener("click", event => { if (event.target === modal) modal.classList.add("hidden"); });

            const categoryModal = document.getElementById("categoryModal");
            document.querySelectorAll("[data-open-category-modal]").forEach(btn => btn.addEventListener("click", () => {
                document.getElementById("categoryForm")?.reset();
                categoryModal?.classList.remove("hidden");
            }));
            document.querySelectorAll("[data-close-category-modal]").forEach(btn => btn.addEventListener("click", () => categoryModal?.classList.add("hidden")));
            categoryModal?.addEventListener("click", event => { if (event.target === categoryModal) categoryModal.classList.add("hidden"); });

            const staffModal = document.getElementById("staffModal");
            document.querySelectorAll("[data-open-staff-modal]").forEach(btn => btn.addEventListener("click", () => {
                document.getElementById("staffForm")?.reset();
                staffModal?.classList.remove("hidden");
            }));
            document.querySelectorAll("[data-close-staff-modal]").forEach(btn => btn.addEventListener("click", () => staffModal?.classList.add("hidden")));
            staffModal?.addEventListener("click", event => { if (event.target === staffModal) staffModal.classList.add("hidden"); });

            const supplierModal = document.getElementById("supplierModal");
            document.querySelectorAll("[data-open-supplier-modal]").forEach(btn => btn.addEventListener("click", () => {
                document.getElementById("supplierForm")?.reset();
                supplierModal?.classList.remove("hidden");
            }));
            document.querySelectorAll("[data-close-supplier-modal]").forEach(btn => btn.addEventListener("click", () => supplierModal?.classList.add("hidden")));
            supplierModal?.addEventListener("click", event => { if (event.target === supplierModal) supplierModal.classList.add("hidden"); });

            const promoModal = document.getElementById("promoModal");
            document.querySelectorAll("[data-open-promo-modal]").forEach(btn => btn.addEventListener("click", () => {
                document.getElementById("promoForm")?.reset();
                promoModal?.classList.remove("hidden");
            }));
            document.querySelectorAll("[data-close-promo-modal]").forEach(btn => btn.addEventListener("click", () => promoModal?.classList.add("hidden")));
            promoModal?.addEventListener("click", event => { if (event.target === promoModal) promoModal.classList.add("hidden"); });

            const filterProducts = () => {
                const keyword = (productSearch?.value ?? "").trim().toLowerCase();
                const category = productCategory?.value ?? "";
                const status = productStatus?.value ?? "";
                const maxPrice = Number(productMaxPrice?.value || 0);

                productRows.forEach(row => {
                    const text = `${row.dataset.name ?? ""} ${row.dataset.code ?? ""}`.toLowerCase();
                    const price = Number(row.dataset.price || 0);
                    const matchedKeyword = !keyword || text.includes(keyword);
                    const matchedCategory = !category || row.dataset.category === category;
                    const matchedStatus = !status || row.dataset.status === status;
                    const matchedPrice = !maxPrice || price <= maxPrice;
                    row.classList.toggle("hidden", !(matchedKeyword && matchedCategory && matchedStatus && matchedPrice));
                });
            };

            [productSearch, productCategory, productStatus, productMaxPrice].forEach(input => {
                input?.addEventListener("input", filterProducts);
                input?.addEventListener("change", filterProducts);
            });

            const orderSearch = document.getElementById("orderSearch");
            const orderChannel = document.getElementById("orderChannel");
            const orderStatusFilter = document.getElementById("orderStatus");
            const orderRows = document.querySelectorAll("[data-order-row]");

            const filterOrders = () => {
                const keyword = (orderSearch?.value ?? "").trim().toLowerCase();
                const channel = orderChannel?.value ?? "";
                const status = orderStatusFilter?.value ?? "";

                orderRows.forEach(row => {
                    const code = (row.dataset.code ?? "").toLowerCase();
                    const matchedKeyword = !keyword || code.includes(keyword);
                    const matchedChannel = !channel || row.dataset.channel === channel;
                    const matchedStatus = !status || row.dataset.status === status;
                    row.classList.toggle("hidden", !(matchedKeyword && matchedChannel && matchedStatus));
                });
            };

            [orderSearch, orderChannel, orderStatusFilter].forEach(input => {
                input?.addEventListener("input", filterOrders);
                input?.addEventListener("change", filterOrders);
            });

            document.querySelectorAll("[data-open-panel]").forEach(btn => btn.addEventListener("click", () => {
                const invoiceId = btn.dataset.invoiceId;
                const template = invoiceId ? document.getElementById(`invoice-template-${invoiceId}`) : null;
                const title = document.getElementById("invoicePanelTitle");
                const body = document.getElementById("invoicePanelBody");

                if (template && body) {
                    if (title) title.textContent = `Chi tiết hóa đơn HD-${invoiceId.toString().padStart(4, "0")}`;
                    body.innerHTML = "";
                    body.appendChild(template.content.cloneNode(true));
                }

                panel?.classList.remove("translate-x-full");
            }));
            document.querySelectorAll("[data-close-panel]").forEach(btn => btn.addEventListener("click", () => panel?.classList.add("translate-x-full")));

            document.querySelectorAll("[data-open-customer-panel]").forEach(btn => btn.addEventListener("click", () => {
                const customerId = btn.dataset.customerId;
                const template = customerId ? document.getElementById(`customer-template-${customerId}`) : null;
                const title = document.getElementById("customerPanelTitle");
                const body = document.getElementById("customerPanelBody");

                if (template && body) {
                    if (title) title.textContent = `Chi tiết khách hàng KH-${customerId.toString().padStart(4, "0")}`;
                    body.innerHTML = "";
                    body.appendChild(template.content.cloneNode(true));
                }

                customerPanel?.classList.remove("translate-x-full");
            }));
            document.querySelectorAll("[data-close-customer-panel]").forEach(btn => btn.addEventListener("click", () => customerPanel?.classList.add("translate-x-full")));

            const syncPageFromHash = () => {
                const hash = location.hash.replace("#", "");
                if (hash && document.querySelector(`[data-page="${hash}"]`)) showPage(hash);
            };

            window.addEventListener("hashchange", syncPageFromHash);
            syncPageFromHash();
            setTimeout(syncPageFromHash, 0);
        })();

        setTimeout(() => {
            const pageName = location.hash.replace("#", "");
            if (!pageName) return;
            document.querySelectorAll("[data-page]").forEach(page => page.classList.toggle("hidden", page.dataset.page !== pageName));
            document.querySelectorAll("[data-page-link]").forEach(link => link.classList.toggle("is-active", link.dataset.pageLink === pageName));
        }, 50);
    </script>
}
