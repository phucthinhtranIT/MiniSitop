@using System.Globalization
@using WebQLministop.Models
@{
    ViewData["Title"] = "Tổng quan";
    ViewData["PageHeading"] = "Tổng quan cửa hàng";
    ViewData["HideCategories"] = true;

    var culture = new CultureInfo("vi-VN");
    var sanPhams = ViewBag.SanPhams as List<SanPham> ?? new List<SanPham>();
    var donHangs = ViewBag.DonHangs as List<DonHang> ?? new List<DonHang>();
    var khachHangs = ViewBag.KhachHangs as List<KhachHang> ?? new List<KhachHang>();
    var nhanViens = ViewBag.NhanViens as List<NhanVien> ?? new List<NhanVien>();
    var khuyenMais = ViewBag.KhuyenMais as List<KhuyenMai> ?? new List<KhuyenMai>();
    var danhMucs = ViewBag.DanhMucs as List<DanhMuc> ?? new List<DanhMuc>();
    var nhaCungCaps = ViewBag.NhaCungCaps as List<NhaCungCap> ?? new List<NhaCungCap>();
    var topSanPhams = donHangs
        .SelectMany(d => d.ChiTiet)
        .Where(c => c.SanPham != null)
        .GroupBy(c => c.SanPham!.Ten)
        .Select(g => new { Ten = g.Key, SoLuong = g.Sum(c => c.SoLuong) })
        .OrderByDescending(x => x.SoLuong)
        .Take(5)
        .ToList();

    decimal doanhThuHomNay = ViewBag.DoanhThuHomNay ?? 0m;
    int soHoaDonHomNay = ViewBag.SoHoaDonHomNay ?? 0;
    int sanPhamSapHet = ViewBag.SanPhamSapHet ?? 0;
    int nhanVienKichHoat = ViewBag.NhanVienKichHoat ?? 0;
    int khachHangKichHoat = ViewBag.KhachHangKichHoat ?? 0;
    int khuyenMaiDangChay = ViewBag.KhuyenMaiDangChay ?? 0;
    int khuyenMaiSapHetHan = ViewBag.KhuyenMaiSapHetHan ?? 0;
    int khuyenMaiDaKetThuc = ViewBag.KhuyenMaiDaKetThuc ?? 0;

    string Money(decimal value) => string.Format(culture, "{0:N0}đ", value);
    string RawNumber(decimal value) => value.ToString(CultureInfo.InvariantCulture);
    string DateText(DateTime value) => value.ToLocalTime().ToString("dd/MM/yyyy", culture);
    string TimeText(DateTime value) => value.ToLocalTime().ToString("HH:mm", culture);
    string ProductStatus(SanPham product) => !product.KichHoat ? "Ngừng bán" : product.TonKho <= 0 ? "Hết hàng" : product.TonKho <= product.MucCanNhapLai ? "Sắp hết" : "Đang bán";
    string ProductBadge(SanPham product) => !product.KichHoat || product.TonKho <= 0 ? "danger" : product.TonKho <= product.MucCanNhapLai ? "warning" : "success";
    string OrderBadge(string status) => status == "ThanhCong" || status == "DaThanhToan" ? "success" : status == "ChoXuLy" || status == "DangXuLy" ? "warning" : "info";
    string OrderText(string? status) => status switch
    {
        "ThanhCong" => "Thành công",
        "ChoXuLy" => "Chờ xử lý",
        "DaThanhToan" => "Đã thanh toán",
        "DangXuLy" => "Đang xử lý",
        "DaHuy" => "Đã hủy",
        _ => string.IsNullOrWhiteSpace(status) ? "Chưa rõ" : status
    };
    string HienThiDanhMuc(string? ten) => ten switch
    {
        "Do uong" => "Đồ uống",
        "Banh keo" => "Bánh kẹo",
        "Thuc pham" => "Thực phẩm",
        "Gia dung" => "Gia dụng",
        _ => string.IsNullOrWhiteSpace(ten) ? "Chưa phân loại" : ten
    };
    string HienThiChucVu(string? chucVu) => chucVu switch
    {
        "Quan ly" => "Quản lý",
        "Nhan vien" => "Nhân viên",
        "Thu ngan" => "Thu ngân",
        "Pha che" => "Pha chế",
        "Kho" => "Kho",
        _ => string.IsNullOrWhiteSpace(chucVu) ? "Chưa phân quyền" : chucVu
    };
    string HienThiThanhToan(string? phuongThuc) => phuongThuc switch
    {
        "TienMat" => "Tiền mặt",
        "ChuyenKhoan" => "Chuyển khoản",
        _ => string.IsNullOrWhiteSpace(phuongThuc) ? "Chưa rõ" : phuongThuc
    };
    string PromoBadge(KhuyenMai promo) => promo.NgayKetThuc < DateTime.UtcNow ? "danger" : promo.NgayKetThuc <= DateTime.UtcNow.AddDays(7) ? "warning" : "success";
    string PromoText(KhuyenMai promo) => promo.NgayKetThuc < DateTime.UtcNow ? "Đã kết thúc" : promo.NgayKetThuc <= DateTime.UtcNow.AddDays(7) ? "Sắp hết hạn" : "Đang chạy";

    var chartDays = Enumerable.Range(0, 7)
        .Select(offset => DateTime.UtcNow.Date.AddDays(offset - 6))
        .Select(day => new
        {
            Day = day,
            Total = donHangs.Where(o => o.NgayDat.Date == day).Sum(o => o.TongTien)
        })
        .ToList();
    var maxChartTotal = chartDays.Any() ? chartDays.Max(d => d.Total) : 0m;
}

<div class="manager-page-stack">
    @if (TempData["QuanLyMessage"] is string quanLyMessage)
    {
        <div class="alert-row @(TempData["QuanLyMessageType"]?.ToString() == "danger" ? "danger" : "info")"><span>i</span><p>@quanLyMessage</p></div>
    }

    <section id="dashboard" class="manager-page space-y-6" data-page="dashboard">
        <div class="manager-hero">
            <div>
                <p class="eyebrow">Dashboard</p>
                <h2 style="font-size: 2.5rem; font-weight: 800; line-height: 1.2;">Tổng quan cửa hàng</h2>

            </div>
            <div class="hero-panel">
                <span>Doanh thu hôm nay</span>
                <strong>@Money(doanhThuHomNay)</strong>
                <small class="text-sky-100">@soHoaDonHomNay hóa đơn trong ngày</small>
            </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><span class="stat-icon bg-blue-100 text-blue-700 dark:bg-blue-500/15 dark:text-blue-200">₫</span><p>Doanh thu hôm nay</p><strong>@Money(doanhThuHomNay)</strong><small>Từ hóa đơn hôm nay</small></article>
            <article class="stat-card"><span class="stat-icon bg-sky-100 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">#</span><p>Số hóa đơn</p><strong>@soHoaDonHomNay</strong><small>@donHangs.Count tổng hóa đơn</small></article>
            <article class="stat-card"><span class="stat-icon bg-amber-100 text-amber-700 dark:bg-amber-400/15 dark:text-amber-200">!</span><p>Sản phẩm sắp hết</p><strong>@sanPhamSapHet</strong><small>@sanPhams.Count sản phẩm đang quản lý</small></article>
            <article class="stat-card"><span class="stat-icon bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200">◎</span><p>Nhân viên hoạt động</p><strong>@nhanVienKichHoat</strong><small>@nhanViens.Count hồ sơ nhân viên</small></article>
        </div>

        <div class="grid gap-5 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,.85fr)]">
            <article class="manager-card">
                <div class="card-head">
                    <div><p class="eyebrow">Revenue</p><h3>Doanh thu 7 ngày</h3></div>
                    <button class="btn-ghost" type="button" onclick="window.location.href='/QuanLy/QuanLy/XuatBaoCaoExcel'">Xuất báo cáo</button>
                </div>
                <div class="chart-bars" aria-label="Biểu đồ doanh thu 7 ngày">
                    @foreach (var day in chartDays)
                    {
                        var percent = maxChartTotal <= 0 ? 0 : Math.Max(8, (int)Math.Round(day.Total / maxChartTotal * 100));
                        <span style="--h:@percent%"><b>@day.Day.ToLocalTime().ToString("dd/MM", culture)</b></span>
                    }
                </div>
            </article>

            <article class="manager-card">
                <div class="card-head"><div><p class="eyebrow">Best sellers</p><h3>Sản phẩm bán chạy</h3></div></div>
                @if (topSanPhams.Any())
                {
                    <div class="space-y-4">
                        @{ var rank = 1; }
                        @foreach (var item in topSanPhams)
                        {
                            <div class="rank-row" style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #1e293b;">
                                <div style="display: flex; gap: 12px; align-items: center;">
                                    <span style="font-weight: bold; color: #64748b;">@rank.ToString("00")</span>
                                    <div>
                                        <strong style="display: block;">@(item.Ten.Replace("Khan giay 4 lop", "Khăn giấy 4 lớp").Replace("Mi Omachi", "Mì Omachi"))</strong>
                                        <small style="display: block; color: #9ca3af; margin-top: 2px;">Đã bán @item.SoLuong sản phẩm</small>
                                    </div>
                                </div>
                            </div>
                            rank++;
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact"><span>◇</span><h3>Chưa có dữ liệu bán chạy</h3><p>Khi có hóa đơn, danh sách sản phẩm bán chạy sẽ hiển thị tại đây.</p></div>
                }
            </article>
        </div>

        <div class="grid gap-5 xl:grid-cols-[minmax(0,1.25fr)_minmax(320px,.75fr)]">
            <article class="manager-card overflow-hidden">
                <div class="card-head"><div><p class="eyebrow">Orders</p><h3>Đơn hàng gần đây</h3></div><button class="btn-secondary" type="button" data-page-link="orders">Xem tất cả</button></div>
                <div class="table-wrap">
                    <table class="manager-table">
                        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Nhân viên</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thời gian</th></tr></thead>
                        <tbody>
                            @foreach (var order in donHangs.Take(5))
                            {
                                <tr><td>HD-@order.Id.ToString("0000")</td><td>@(order.KhachHang?.HoTen?.Replace("Khach le", "Khách lẻ").Replace("Khach Hang Mau", "Khách hàng mẫu") ?? "Khách lẻ")</td><td>@(order.NhanVien?.HoTen?.Replace("Quan Ly Mau", "Quản lý mẫu") ?? "Chưa gán")</td><td>@Money(order.TongTien)</td><td><span class="badge @OrderBadge(order.TrangThai)">@OrderText(order.TrangThai)</span></td><td>@TimeText(order.NgayDat)</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!donHangs.Any())
                {
                    <div class="empty-state compact"><span>◇</span><h3>Chưa có hóa đơn</h3><p>Dữ liệu hóa đơn sẽ xuất hiện sau khi hệ thống phát sinh đơn hàng.</p></div>
                }
            </article>

            <div class="grid gap-5">
                <article class="manager-card">
                    <div class="card-head"><div><p class="eyebrow">Alert</p><h3>Cảnh báo tồn kho</h3></div></div>
                    <div class="space-y-3">
                        @foreach (var product in sanPhams.Where(p => p.TonKho <= p.MucCanNhapLai).Take(4))
                        {
                            <div class="alert-row @(product.TonKho <= 0 ? "danger" : "warning")"><span>!</span><p>@product.Ten còn @product.TonKho @product.DonVi</p></div>
                        }
                        @if (!sanPhams.Any(p => p.TonKho <= p.MucCanNhapLai))
                        {
                            <div class="alert-row info"><span>i</span><p>Không có sản phẩm dưới mức cần nhập lại.</p></div>
                        }
                    </div>
                </article>
                <article class="manager-card">
                    <div class="card-head"><div><p class="eyebrow">Promotion</p><h3>Khuyến mãi đang chạy</h3></div></div>
                    <div class="timeline">
                        @foreach (var promo in khuyenMais.Where(p => p.KichHoat && p.NgayBatDau <= DateTime.UtcNow && p.NgayKetThuc >= DateTime.UtcNow).Take(3))
                        {
                            <div style="display: flex; gap: 12px; padding: 8px 0; border-bottom: 1px solid #1e293b;">
                                <span></span>
                                <div>
                                    <strong style="display: block;">@promo.Ten</strong>
                                    <small style="display: block; color: #9ca3af; margin-top: 2px;">Giảm @promo.PhanTramGiam.ToString("0.##")% • @DateText(promo.NgayBatDau) - @DateText(promo.NgayKetThuc)</small>
                                </div>
                            </div>
                        }
                        @if (!khuyenMais.Any(p => p.KichHoat && p.NgayBatDau <= DateTime.UtcNow && p.NgayKetThuc >= DateTime.UtcNow))
                        {
                            <div><span></span><strong>Chưa có khuyến mãi</strong><small>Tạo chương trình khuyến mãi để hiển thị tại đây.</small></div>
                        }
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section id="products" class="manager-page hidden space-y-6" data-page="products">
        <div class="page-title-row"><div><p class="eyebrow">Products</p><h2>Quản lý sản phẩm</h2></div><button class="btn-primary" data-open-modal type="button">Thêm sản phẩm</button></div>
        @if (TempData["SanPhamMessage"] is string sanPhamMessage)
        {
            <div class="alert-row @(TempData["SanPhamMessageType"]?.ToString() == "danger" ? "danger" : "info")"><span>i</span><p>@sanPhamMessage</p></div>
        }
        <div class="filter-panel">
            <label><span>Tìm kiếm</span><input data-product-search type="search" placeholder="Tên hoặc mã sản phẩm"></label>
            <label><span>Danh mục</span><select data-product-category><option value="">Tất cả danh mục</option>@foreach (var category in danhMucs){<option value="@category.Id">@HienThiDanhMuc(category.Ten)</option>}</select></label>
            <label><span>Trạng thái</span><select data-product-status><option value="">Tất cả trạng thái</option><option value="Đang bán">Đang bán</option><option value="Sắp hết">Sắp hết</option><option value="Hết hàng">Hết hàng</option><option value="Ngừng bán">Ngừng bán</option></select></label>
            <label><span>Giá tối đa</span><input data-product-max-price type="number" min="0" step="1000" placeholder="Ví dụ 20000"></label>
        </div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap">
                <table class="manager-table">
                    <thead><tr><th>Ảnh</th><th>Mã SP</th><th>Tên sản phẩm</th><th>Danh mục</th><th>Giá bán</th><th>Tồn kho</th><th>Trạng thái</th><th>Hành động</th></tr></thead>
                    <tbody>
                        @foreach (var product in sanPhams)
                        {
                            <tr data-product-row
                                data-name="@product.Ten"
                                data-code="@product.Ma"
                                data-category="@product.DanhMucId"
                                data-status="@ProductStatus(product)"
                                data-price="@RawNumber(product.GiaBan)">
                                <td>
                                    <span class="product-thumb">
                                        @if (!string.IsNullOrWhiteSpace(product.HinhAnh))
                                        {
                                            <img src="@product.HinhAnh" alt="@product.Ten" class="h-full w-full rounded-xl object-cover" />
                                        }
                                        else
                                        {
                                            @product.Ten.FirstOrDefault()
                                        }
                                    </span>
                                </td>
                                <td>@product.Ma</td>
                                <td>
                                    <strong>@product.Ten</strong>
                                    <small class="block text-slate-500">@(!string.IsNullOrWhiteSpace(product.MoTa) ? product.MoTa : "Chưa có mô tả")</small>
                                </td>
                                <td>@HienThiDanhMuc(product.DanhMuc?.Ten)</td>
                                <td>@Money(product.GiaBan)</td>
                                <td>@product.TonKho @product.DonVi</td>
                                <td><span class="badge @ProductBadge(product)">@ProductStatus(product)</span></td>
                                <td>
                                    <div class="order-actions">
                                        <button class="btn-secondary" type="button"
                                                data-edit-product
                                                data-id="@product.Id"
                                                data-ma="@product.Ma"
                                                data-ten="@product.Ten"
                                                data-mota="@product.MoTa"
                                                data-hinhanh="@product.HinhAnh"
                                                data-danhmucid="@product.DanhMucId"
                                                data-nhacungcapid="@product.NhaCungCapId"
                                                data-giavon="@RawNumber(product.GiaVon)"
                                                data-giaban="@RawNumber(product.GiaBan)"
                                                data-donvi="@product.DonVi"
                                                data-tonkho="@product.TonKho"
                                                data-muccannhaplai="@product.MucCanNhapLai"
                                                data-kichhoat="@product.KichHoat.ToString().ToLowerInvariant()">Sửa</button>
                                        <form asp-area="QuanLy" asp-controller="QuanLy" asp-action="ToggleSanPham" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@product.Id">
                                            <button class="btn-secondary" type="submit">@(product.KichHoat ? "Ngừng bán" : "Bật bán")</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!sanPhams.Any())
            {
                <div class="empty-state compact"><span>□</span><h3>Chưa có sản phẩm</h3><p>Thêm sản phẩm đầu tiên để bắt đầu quản lý tồn kho.</p></div>
            }
            <div class="pagination-bar"><button type="button">‹</button><button class="active" type="button">1</button><button type="button">›</button></div>
        </article>
    </section>

    <section id="categories" class="manager-page hidden space-y-6" data-page="categories">
        <div class="page-title-row">
            <div>
                <p class="eyebrow">Categories</p>
                <h2>Quản lý danh mục</h2>
            </div>
            <button class="btn-primary" data-open-category-modal type="button">Thêm danh mục</button>
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng danh mục</p><strong>@danhMucs.Count</strong><small>Đang có trong hệ thống</small></article>
            <article class="stat-card"><p>Danh mục có hàng</p><strong>@danhMucs.Count(d => sanPhams.Any(p => p.DanhMucId == d.Id))</strong><small>Có sản phẩm liên kết</small></article>
            <article class="stat-card"><p>Sản phẩm đã phân loại</p><strong>@sanPhams.Count(p => p.DanhMucId > 0)</strong><small>Từ bảng SanPhams</small></article>
            <article class="stat-card"><p>Trung bình</p><strong>@(danhMucs.Any() ? Math.Round((decimal)sanPhams.Count / danhMucs.Count, 1) : 0)</strong><small>Sản phẩm/danh mục</small></article>
        </div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap">
                <table class="manager-table">
                    <thead><tr><th>Mã DM</th><th>Tên danh mục</th><th>Mô tả</th><th>Số sản phẩm</th><th>Cập nhật</th></tr></thead>
                    <tbody>
                        @foreach (var category in danhMucs)
                        {
                            <tr>
                                <td>DM-@category.Id.ToString("0000")</td>
                                <td><strong>@HienThiDanhMuc(category.Ten)</strong></td>
                                <td>@(category.MoTa ?? "-")</td>
                                <td><span class="badge info">@sanPhams.Count(p => p.DanhMucId == category.Id) sản phẩm</span></td>
                                <td>
                                    <form asp-area="QuanLy" asp-controller="QuanLy" asp-action="UpdateDanhMuc" method="post" class="inline-form category-inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@category.Id">
                                        <input name="Ten" value="@category.Ten" maxlength="100" required>
                                        <input name="MoTa" value="@category.MoTa" maxlength="250" placeholder="Mô tả">
                                        <button class="btn-secondary" type="submit">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!danhMucs.Any())
            {
                <div class="empty-state compact"><span>DM</span><h3>Chưa có danh mục</h3><p>Thêm danh mục để phân loại sản phẩm trong cửa hàng.</p></div>
            }
        </article>
    </section>

    <section id="orders" class="manager-page hidden space-y-6" data-page="orders">
        <div class="page-title-row"><div><p class="eyebrow">Orders</p><h2>Quản lý đơn hàng</h2></div></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng đơn hôm nay</p><strong>@soHoaDonHomNay</strong><small>Từ dữ liệu DonHangs</small></article>
            <article class="stat-card"><p>Đã thanh toán</p><strong>@donHangs.Count(o => o.TrangThai == "DaThanhToan")</strong><small>Trạng thái đã thanh toán</small></article>
            <article class="stat-card"><p>Đang xử lý</p><strong>@donHangs.Count(o => o.TrangThai == "DangXuLy")</strong><small>Trạng thái đang xử lý</small></article>
            <article class="stat-card"><p>Doanh thu đơn hàng</p><strong>@Money(donHangs.Sum(o => o.TongTien))</strong><small>Tổng toàn bộ hóa đơn</small></article>
        </div>
        <div class="filter-panel">
            <label><span>Mã đơn</span><input id="orderSearch" placeholder="Nhập mã hóa đơn"></label>
            <label><span>Kênh bán</span><select id="orderChannel"><option value="">Tất cả</option><option value="Web">Web</option><option value="Tại quầy">Tại quầy</option></select></label>
            <label><span>Trạng thái</span><select id="orderStatus"><option value="">Tất cả</option><option value="Đã thanh toán">Đã thanh toán</option><option value="Đang xử lý">Đang xử lý</option><option value="Thành công">Thành công</option><option value="Đã hủy">Đã hủy</option></select></label>
        </div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Kênh bán</th><th>Địa chỉ</th><th>Nhân viên</th><th>SL</th><th>Tổng tiền</th><th>Thanh toán</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var order in donHangs){<tr data-order-row data-code="HD-@order.Id.ToString("0000")" data-channel="@(order.KenhBanHang == "Web" ? "Web" : "Tại quầy")" data-status="@OrderText(order.TrangThai)"><td>HD-@order.Id.ToString("0000")</td><td>@(order.KhachHang?.HoTen?.Replace("Khach le", "Khách lẻ").Replace("Khach Hang Mau", "Khách hàng mẫu") ?? "Khách lẻ")</td><td><span class="badge info">@(order.KenhBanHang == "Web" ? "Web" : "Tại quầy")</span></td><td><small>@(string.IsNullOrWhiteSpace(order.DiaChiGiaoHang) ? "Tại quầy" : order.DiaChiGiaoHang)</small></td><td>@(order.NhanVien?.HoTen?.Replace("Quan Ly Mau", "Quản lý mẫu") ?? "Hệ thống Web")</td><td>@order.ChiTiet.Sum(i => i.SoLuong)</td><td>@Money(order.TongTien)</td><td>@HienThiThanhToan(order.PhuongThucThanhToan)</td><td><span class="badge @OrderBadge(order.TrangThai)">@OrderText(order.TrangThai)</span></td><td><div class="order-actions"><button class="invoice-detail-btn" data-open-panel data-invoice-id="@order.Id" type="button">Xem chi tiết</button><form asp-area="QuanLy" asp-controller="QuanLy" asp-action="CapNhatTrangThaiDonHang" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@order.Id"><select name="trangThai"><option value="DangXuLy" selected="@(order.TrangThai == "DangXuLy")">Đang xử lý</option><option value="DaThanhToan" selected="@(order.TrangThai == "DaThanhToan")">Đã thanh toán</option><option value="ThanhCong" selected="@(order.TrangThai == "ThanhCong")">Thành công</option><option value="DaHuy" selected="@(order.TrangThai == "DaHuy")">Đã hủy</option></select><button class="btn-secondary" type="submit">Lưu</button></form></div></td></tr>}</tbody></table></div>
            @if (!donHangs.Any()){<div class="empty-state compact"><span>◇</span><h3>Chưa có đơn hàng</h3><p>Hóa đơn sẽ hiển thị tại đây khi được tạo.</p></div>}
        </article>
    </section>

    <section id="customers" class="manager-page hidden space-y-6" data-page="customers">
        <div class="page-title-row"><div><p class="eyebrow">Customers</p><h2>Quản lý khách hàng</h2></div><button class="btn-secondary" type="button">Xuất danh sách</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng khách hàng</p><strong>@khachHangs.Count</strong><small>Tất cả hồ sơ</small></article><article class="stat-card"><p>Tổng điểm thưởng</p><strong>@khachHangs.Sum(c => c.DiemThuong)</strong><small>Từ điểm thưởng</small></article><article class="stat-card"><p>Điểm trung bình</p><strong>@(khachHangs.Any() ? Math.Round(khachHangs.Average(c => c.DiemThuong), 0) : 0)</strong><small>Điểm/khách</small></article>
        </div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã KH</th><th>Tên khách hàng</th><th>SĐT</th><th>Email</th><th>Điểm thưởng</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var customer in khachHangs){<tr><td>KH-@customer.Id.ToString("0000")</td><td>@customer.HoTen</td><td>@(customer.DienThoai ?? "-")</td><td>@(customer.Email ?? "-")</td><td>@customer.DiemThuong</td><td><span class="badge @(customer.KichHoat ? "success" : "danger")">@(customer.KichHoat ? "Đang hoạt động" : "Ngừng")</span></td><td><button class="btn-secondary" data-open-customer-panel data-customer-id="@customer.Id" type="button">Chi tiết</button></td></tr>}</tbody></table></div>@if (!khachHangs.Any()){<div class="empty-state compact"><span>○</span><h3>Chưa có khách hàng</h3><p>Dữ liệu khách hàng sẽ xuất hiện khi có hồ sơ trong hệ thống.</p></div>}</article>
    </section>

    <section id="staff" class="manager-page hidden space-y-6" data-page="staff">
        <div class="page-title-row"><div><p class="eyebrow">Staff</p><h2>Quản lý nhân viên</h2></div><button class="btn-primary" data-open-staff-modal type="button">Thêm nhân viên</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            @foreach (var staff in nhanViens.Take(4))
            {
                <article class="employee-card"><span>@staff.HoTen.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault()?.FirstOrDefault()</span><div><strong>@staff.HoTen</strong><small>@HienThiChucVu(staff.ChucVu)</small></div><em class="badge @(staff.KichHoat ? "success" : "danger")">@(staff.KichHoat ? "Đang hoạt động" : "Ngừng")</em></article>
            }
        </div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã NV</th><th>Họ tên</th><th>SĐT</th><th>Email</th><th>Chức vụ / role</th><th>Lương</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var staff in nhanViens){<tr><td>NV-@staff.Id.ToString("0000")</td><td>@staff.HoTen</td><td>@(staff.DienThoai ?? "-")</td><td>@(staff.Email ?? "-")</td><td><form asp-area="QuanLy" asp-controller="QuanLy" asp-action="CapNhatChucVuNhanVien" method="post" class="inline-form role-inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@staff.Id"><select name="chucVu"><option value="Nhan vien" selected="@(staff.ChucVu == "Nhan vien")">Nhân viên</option><option value="Thu ngan" selected="@(staff.ChucVu == "Thu ngan")">Thu ngân</option><option value="Pha che" selected="@(staff.ChucVu == "Pha che")">Pha chế</option><option value="Kho" selected="@(staff.ChucVu == "Kho")">Kho</option><option value="Quan ly" selected="@(staff.ChucVu == "Quan ly")">Quản lý</option></select><button class="btn-secondary" type="submit">Lưu role</button></form></td><td>@Money(staff.Luong)</td><td><span class="badge @(staff.KichHoat ? "success" : "danger")">@(staff.KichHoat ? "Đang hoạt động" : "Ngừng")</span></td><td><form asp-area="QuanLy" asp-controller="QuanLy" asp-action="ToggleNhanVien" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@staff.Id"><button class="btn-secondary" type="submit">@(staff.KichHoat ? "Ngừng" : "Kích hoạt")</button></form></td></tr>}</tbody></table></div>@if (!nhanViens.Any()){<div class="empty-state compact"><span>◎</span><h3>Chưa có nhân viên</h3><p>Thêm nhân viên để quản lý hồ sơ và phân quyền.</p></div>}</article>
    </section>

    <section id="suppliers" class="manager-page hidden space-y-6" data-page="suppliers">
        <div class="page-title-row"><div><p class="eyebrow">Suppliers</p><h2>Quản lý nhà cung cấp</h2></div><button class="btn-primary" data-open-supplier-modal type="button">Thêm nhà cung cấp</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng nhà cung cấp</p><strong>@nhaCungCaps.Count</strong><small>Đối tác đang lưu trong hệ thống</small></article>
            <article class="stat-card"><p>Sản phẩm có NCC</p><strong>@sanPhams.Count(p => p.NhaCungCapId > 0)</strong><small>Từ bảng SanPhams</small></article>
            <article class="stat-card"><p>NCC có email</p><strong>@nhaCungCaps.Count(n => !string.IsNullOrWhiteSpace(n.Email))</strong><small>Dễ liên hệ đặt hàng</small></article>
            <article class="stat-card"><p>NCC có điện thoại</p><strong>@nhaCungCaps.Count(n => !string.IsNullOrWhiteSpace(n.DienThoai))</strong><small>Dùng khi cần nhập hàng nhanh</small></article>
        </div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap">
                <table class="manager-table">
                    <thead><tr><th>Mã NCC</th><th>Nhà cung cấp</th><th>Người liên hệ</th><th>SĐT</th><th>Email</th><th>Địa chỉ</th><th>Số sản phẩm</th><th>Hành động</th></tr></thead>
                    <tbody>
                        @foreach (var supplier in nhaCungCaps)
                        {
                            var productCount = sanPhams.Count(p => p.NhaCungCapId == supplier.Id);
                            <tr>
                                <td>NCC-@supplier.Id.ToString("0000")</td>
                                <td>@supplier.Ten</td>
                                <td>@(supplier.TenLienHe ?? "-")</td>
                                <td>@(supplier.DienThoai ?? "-")</td>
                                <td>@(supplier.Email ?? "-")</td>
                                <td>@(supplier.DiaChi ?? "-")</td>
                                <td><span class="badge info">@productCount sản phẩm</span></td>
                                <td><button class="btn-secondary" type="button">Chi tiết</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!nhaCungCaps.Any())
            {
                <div class="empty-state compact"><span>C</span><h3>Chưa có nhà cung cấp</h3><p>Khi thêm nhà cung cấp, quản lý có thể theo dõi nguồn hàng tại đây.</p></div>
            }
        </article>
    </section>

    <section id="promotions" class="manager-page hidden space-y-6" data-page="promotions">
        <div class="page-title-row"><div><p class="eyebrow">Promotions</p><h2>Quản lý khuyến mãi</h2></div><button class="btn-primary" data-open-promo-modal type="button">Thêm khuyến mãi</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4"><article class="stat-card"><p>Đang chạy</p><strong>@khuyenMaiDangChay</strong><small>KichHoat = true</small></article><article class="stat-card"><p>Sắp hết hạn</p><strong>@khuyenMaiSapHetHan</strong><small>Trong 7 ngày</small></article><article class="stat-card"><p>Đã kết thúc</p><strong>@khuyenMaiDaKetThuc</strong><small>Qua ngày kết thúc</small></article><article class="stat-card"><p>Tổng chương trình</p><strong>@khuyenMais.Count</strong><small>Tất cả khuyến mãi</small></article></div>
        <div class="grid gap-4 lg:grid-cols-3">@foreach (var promo in khuyenMais.Take(3)){<article class="promo-card"><span>KM-@promo.Id.ToString("0000")</span><h3>@promo.Ten</h3><p>@DateText(promo.NgayBatDau) - @DateText(promo.NgayKetThuc)</p><b>@PromoText(promo)</b></article>}</div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã KM</th><th>Tên chương trình</th><th>Giảm giá</th><th>Bắt đầu</th><th>Kết thúc</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var promo in khuyenMais){<tr><td>KM-@promo.Id.ToString("0000")</td><td>@promo.Ten</td><td>@promo.PhanTramGiam.ToString("0.##")%</td><td>@DateText(promo.NgayBatDau)</td><td>@DateText(promo.NgayKetThuc)</td><td><span class="badge @PromoBadge(promo)">@PromoText(promo)</span></td><td><form asp-area="QuanLy" asp-controller="QuanLy" asp-action="ToggleKhuyenMai" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@promo.Id"><button class="btn-secondary" type="submit">@(promo.KichHoat ? "Tắt" : "Bật")</button></form></td></tr>}</tbody></table></div>@if (!khuyenMais.Any()){<div class="empty-state compact"><span>✦</span><h3>Chưa có khuyến mãi</h3><p>Tạo chương trình đầu tiên để bắt đầu quản lý ưu đãi.</p></div>}</article>
    </section>
</div>

<div id="productModal" class="modal-shell hidden" aria-hidden="true">
