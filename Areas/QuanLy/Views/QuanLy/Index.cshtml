                </div>
            </section>

            <section class="product-form-section">
                <div class="form-section-title"><span>2</span><strong>Phân loại & nguồn hàng</strong></div>
                <div class="modal-grid">
                    <label style="grid-column: span 1;">
                        <span>Danh mục</span>
                        <select name="DanhMucId" required>
                            <option value="">Chọn danh mục</option>
                            @foreach (var category in danhMucs)
                            {
                                <option value="@category.Id">@HienThiDanhMuc(category.Ten)</option>
                            }
                        </select>
                    </label>
                    <label style="grid-column: span 2;">
                        <span>Nhà cung cấp</span>
                        <select name="NhaCungCapId" required>
                            <option value="">Chọn nhà cung cấp</option>
                            @foreach (var supplier in nhaCungCaps)
                            {
                                <option value="@supplier.Id">@supplier.Ten</option>
                            }
                        </select>
                    </label>
                </div>
            </section>

            <section class="product-form-section">
                <div class="form-section-title"><span>3</span><strong>Giá bán & tồn kho</strong></div>
                <div class="modal-grid" style="margin-bottom: 0.9rem;">
                    <label><span>Giá nhập</span><input name="GiaVon" type="number" min="0" step="1000" value="0" required></label>
                    <label><span>Giá bán</span><input name="GiaBan" type="number" min="0" step="1000" value="0" required></label>
                    <label><span>Tồn kho hiện tại</span><input name="TonKho" type="number" min="0" step="1" value="0" required></label>
                </div>
                <label style="display: block;"><span>Cảnh báo hết hàng khi tồn kho dưới:</span><input name="MucCanNhapLai" type="number" min="0" step="1" value="10" required></label>
            </section>

            <label class="product-publish-toggle">
                <input name="KichHoat" type="checkbox" value="true" checked>
                <span>
                    <strong>Hiển thị trên trang chủ</strong>
                    <small>Khách có thể tìm thấy sản phẩm và thêm vào giỏ hàng khi trạng thái này được bật.</small>
                </span>
            </label>
        </div>
        <div class="product-modal-actions"><button class="btn-secondary" data-close-modal type="button">Hủy</button><button id="productSubmitText" class="btn-primary" type="submit">Lưu sản phẩm</button></div>
    </form>
</div>

