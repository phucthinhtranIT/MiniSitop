@{
    Layout = "_Layout";
    ViewData["HideCategories"] = true;
    ViewData["HideGuestHeader"] = true;
    ViewData["Title"] = "Đăng nhập";
    var taiKhoan = Context.Request.HasFormContentType ? Context.Request.Form["taiKhoan"].ToString() : string.Empty;
}

<section class="py-8 md:py-12">
    <div class="mx-auto grid max-w-6xl gap-8 rounded-[32px] border border-sky-100 bg-white/95 p-6 shadow-2xl shadow-sky-100 lg:grid-cols-[1.05fr_0.95fr] lg:p-10">
        <div class="rounded-[28px] bg-gradient-to-br from-slate-900 via-sky-900 to-blue-700 p-8 text-white shadow-xl lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-100">MiniStop</p>
            <h1 class="mt-4 text-3xl font-black md:text-4xl">Đăng nhập để tiếp tục đúng vai trò.</h1>
            <p class="mt-4 max-w-md text-sky-100/90">Khách hàng mua sắm và tích điểm, nhân viên bán hàng tại quầy, quản lý theo dõi vận hành cửa hàng.</p>
            <ul class="mt-6 space-y-3 text-sm text-sky-100/90">
                <li>Khách hàng: giỏ hàng, lịch sử mua hàng, điểm tích lũy</li>
                <li>Nhân viên: tạo hóa đơn và theo dõi tồn kho tại quầy</li>
                <li>Quản lý: xem dashboard, sản phẩm, đơn hàng và nhân sự</li>
            </ul>
        </div>

        <div class="rounded-[28px] border border-sky-100 bg-sky-50/70 p-8 shadow-inner lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-blue-700">Trang đăng nhập</p>
            <h2 class="mt-3 text-2xl font-bold text-slate-900">Chào mừng bạn quay lại</h2>
            <p class="mt-2 text-slate-600">Khách hàng, nhân viên và quản lý đều đăng nhập tại đây bằng email hoặc số điện thoại.</p>

            @if (TempData["ThongBaoThanhCong"] is string thongBao)
            {
                <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700">
                    @thongBao
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
                    @Html.ValidationSummary(false, "", new { @class = "m-0 list-disc pl-4" })
                </div>
            }

            <form method="post" action="/DangNhap" class="mt-8 space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label for="taiKhoan" class="mb-1 block text-sm font-semibold text-slate-700">Email hoặc số điện thoại</label>
                    <input id="taiKhoan" name="taiKhoan" type="text" value="@taiKhoan" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none ring-0 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="example@ministop.vn" autocomplete="username" />
                </div>
                <div>
                    <label for="matKhau" class="mb-1 block text-sm font-semibold text-slate-700">Mật khẩu</label>
                    <input id="matKhau" name="matKhau" type="password" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="Tối thiểu 6 ký tự" autocomplete="current-password" />
                </div>
                <div class="flex items-center justify-between text-sm">
                    <label class="flex items-center gap-2 text-slate-600"><input name="ghiNho" type="checkbox" class="h-4 w-4 rounded border-sky-300 text-blue-600 focus:ring-blue-500" /> Ghi nhớ đăng nhập</label>
                    <a href="/DangNhap/QuenMatKhau" class="font-semibold text-blue-700 hover:text-blue-800">Quên mật khẩu?</a>
                </div>
                <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-blue-600 to-sky-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-100 transition hover:from-blue-700 hover:to-sky-600">Đăng nhập</button>
                <p class="text-center text-sm text-slate-600">Chưa có tài khoản? <a href="/DangKy" class="font-semibold text-blue-700 hover:text-blue-800">Đăng ký ngay</a></p>
            </form>

            <div class="my-6 flex items-center gap-3">
                <div class="h-px flex-1 bg-sky-200"></div>
                <span class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">hoặc</span>
                <div class="h-px flex-1 bg-sky-200"></div>
            </div>

            <form method="post" action="/DangNhap/DangNhapGoogle">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex w-full items-center justify-center gap-3 rounded-2xl border border-sky-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 shadow-sm transition hover:border-blue-300 hover:text-blue-700">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-white text-sm font-black text-blue-600">G</span>
                    Đăng nhập bằng Google
                </button>
            </form>
        </div>
    </div>
</section>
