@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="text-sm font-semibold text-brand-600">MiniStop</p>
            <h1 class="text-3xl font-black text-slate-900">Giỏ hàng của bạn</h1>
            <p class="mt-2 text-slate-500">Kiểm tra sản phẩm, điều chỉnh số lượng và chuẩn bị tạo đơn hàng.</p>
        </div>
        <a href="/Home/TimKiem" class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-bold text-slate-700 hover:border-brand-300 hover:text-brand-600 text-decoration-none">
            Tiếp tục mua hàng
        </a>
    </div>

    <div id="emptyCart" class="hidden rounded-2xl border border-slate-100 bg-white p-10 text-center shadow-sm">
        <h2 class="text-xl font-bold text-slate-900">Giỏ hàng đang trống</h2>
        <p class="mt-2 text-slate-500">Bạn có thể thêm sản phẩm từ trang chủ hoặc trang tìm kiếm.</p>
        <a href="/" class="mt-6 inline-flex rounded-full bg-brand-600 px-6 py-3 font-bold text-white hover:bg-brand-700 text-decoration-none">Về trang chủ</a>
    </div>

    <div id="cartContent" class="grid gap-6 lg:grid-cols-[1fr_360px]">
        <section id="cartItems" class="space-y-4"></section>

        <aside class="h-fit rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-bold text-slate-900">Tóm tắt đơn hàng</h2>
            <div class="mt-5 space-y-3 border-b border-slate-100 pb-5 text-sm">
                <div class="flex justify-between text-slate-500">
                    <span>Tạm tính</span>
                    <span id="cartTotal" class="font-bold text-slate-900">0đ</span>
                </div>
                <div class="flex justify-between text-slate-500">
                    <span>Khuyến mãi</span>
                    <span>Áp dụng sau</span>
                </div>
            </div>
            <button id="checkoutCart" type="button" class="mt-5 w-full rounded-xl bg-brand-600 px-5 py-3 font-bold text-white hover:bg-brand-700">
                Xác nhận giỏ hàng
            </button>
            <button id="clearCart" type="button" class="mt-3 w-full rounded-xl border border-slate-200 bg-white px-5 py-3 font-bold text-slate-600 hover:border-red-200 hover:text-red-500">
                Xóa toàn bộ
            </button>
            <p class="mt-4 text-xs leading-5 text-slate-400">Phần này đang giữ giỏ hàng ở trình duyệt. Khi bạn cần tạo đơn thật, mình sẽ nối tiếp vào bảng DonHang và ChiTietDonHang.</p>
        </aside>
    </div>
</div>
