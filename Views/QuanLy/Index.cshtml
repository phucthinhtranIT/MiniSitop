@using System.Globalization
@using WebQLministop.Models
@{
    ViewData["Title"] = "Tổng quan";
    ViewData["PageHeading"] = "Tổng quan cửa hàng";
    ViewData["HideCategories"] = true;

    var culture = new CultureInfo("vi-VN");
    var sanPhams = ViewBag.SanPhams as List<SanPham> ?? new List<SanPham>();
    var donHangs = ViewBag.DonHangs as List<DonHang> ?? new List<DonHang>();
    var khachHangs = ViewBag.KhachHangs as List<KhachHang> ?? new List<KhachHang>();
    var nhanViens = ViewBag.NhanViens as List<NhanVien> ?? new List<NhanVien>();
    var khuyenMais = ViewBag.KhuyenMais as List<KhuyenMai> ?? new List<KhuyenMai>();
    var danhMucs = ViewBag.DanhMucs as List<DanhMuc> ?? new List<DanhMuc>();
    var nhaCungCaps = ViewBag.NhaCungCaps as List<NhaCungCap> ?? new List<NhaCungCap>();
    var topSanPhams = ViewBag.TopSanPhams as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();

    decimal doanhThuHomNay = ViewBag.DoanhThuHomNay ?? 0m;
    int soHoaDonHomNay = ViewBag.SoHoaDonHomNay ?? 0;
    int sanPhamSapHet = ViewBag.SanPhamSapHet ?? 0;
    int nhanVienKichHoat = ViewBag.NhanVienKichHoat ?? 0;
    int khachHangKichHoat = ViewBag.KhachHangKichHoat ?? 0;
    int khuyenMaiDangChay = ViewBag.KhuyenMaiDangChay ?? 0;
    int khuyenMaiSapHetHan = ViewBag.KhuyenMaiSapHetHan ?? 0;
    int khuyenMaiDaKetThuc = ViewBag.KhuyenMaiDaKetThuc ?? 0;

    string Money(decimal value) => string.Format(culture, "{0:N0}đ", value);
    string DateText(DateTime value) => value.ToLocalTime().ToString("dd/MM/yyyy", culture);
    string TimeText(DateTime value) => value.ToLocalTime().ToString("HH:mm", culture);
    string ProductStatus(SanPham product) => product.TonKho <= 0 ? "Hết hàng" : product.TonKho <= product.MucCanNhapLai ? "Sắp hết" : "Còn hàng";
    string ProductBadge(SanPham product) => product.TonKho <= 0 ? "danger" : product.TonKho <= product.MucCanNhapLai ? "warning" : "success";
    string OrderBadge(string status) => status == "ThanhCong" || status == "DaThanhToan" ? "success" : status == "ChoXuLy" || status == "DangXuLy" ? "warning" : "info";
    string OrderText(string status) => status == "ThanhCong" ? "Thành công" : status == "ChoXuLy" ? "Chờ xử lý" : status == "DaThanhToan" ? "Đã thanh toán" : status == "DangXuLy" ? "Đang xử lý" : status;
    string PromoBadge(KhuyenMai promo) => promo.NgayKetThuc < DateTime.UtcNow ? "danger" : promo.NgayKetThuc <= DateTime.UtcNow.AddDays(7) ? "warning" : "success";
    string PromoText(KhuyenMai promo) => promo.NgayKetThuc < DateTime.UtcNow ? "Đã kết thúc" : promo.NgayKetThuc <= DateTime.UtcNow.AddDays(7) ? "Sắp hết hạn" : "Đang chạy";

    var chartDays = Enumerable.Range(0, 7)
        .Select(offset => DateTime.UtcNow.Date.AddDays(offset - 6))
        .Select(day => new
        {
            Day = day,
            Total = donHangs.Where(o => o.NgayDat.Date == day).Sum(o => o.TongTien)
        })
        .ToList();
    var maxChartTotal = chartDays.Any() ? chartDays.Max(d => d.Total) : 0m;
}

<div class="manager-page-stack">
    <section id="dashboard" class="manager-page space-y-6" data-page="dashboard">
        <div class="manager-hero">
            <div>
                <p class="eyebrow">Dashboard</p>
                <h2>Tổng quan cửa hàng</h2>
                <p>Dữ liệu đang được lấy từ hệ thống: sản phẩm, hóa đơn, khách hàng, nhân viên và khuyến mãi.</p>
            </div>
            <div class="hero-panel">
                <span>Doanh thu hôm nay</span>
                <strong>@Money(doanhThuHomNay)</strong>
                <small class="text-sky-100">@soHoaDonHomNay hóa đơn trong ngày</small>
            </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><span class="stat-icon bg-blue-100 text-blue-700 dark:bg-blue-500/15 dark:text-blue-200">₫</span><p>Doanh thu hôm nay</p><strong>@Money(doanhThuHomNay)</strong><small>Từ hóa đơn hôm nay</small></article>
            <article class="stat-card"><span class="stat-icon bg-sky-100 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">#</span><p>Số hóa đơn</p><strong>@soHoaDonHomNay</strong><small>@donHangs.Count tổng hóa đơn</small></article>
            <article class="stat-card"><span class="stat-icon bg-amber-100 text-amber-700 dark:bg-amber-400/15 dark:text-amber-200">!</span><p>Sản phẩm sắp hết</p><strong>@sanPhamSapHet</strong><small>@sanPhams.Count sản phẩm đang quản lý</small></article>
            <article class="stat-card"><span class="stat-icon bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200">◎</span><p>Nhân viên hoạt động</p><strong>@nhanVienKichHoat</strong><small>@nhanViens.Count hồ sơ nhân viên</small></article>
        </div>

        <div class="grid gap-5 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,.85fr)]">
            <article class="manager-card">
                <div class="card-head">
                    <div><p class="eyebrow">Revenue</p><h3>Doanh thu 7 ngày</h3></div>
                    <button class="btn-ghost" type="button">Xuất báo cáo</button>
                </div>
                <div class="chart-bars" aria-label="Biểu đồ doanh thu 7 ngày">
                    @foreach (var day in chartDays)
                    {
                        var percent = maxChartTotal <= 0 ? 0 : Math.Max(8, (int)Math.Round(day.Total / maxChartTotal * 100));
                        <span style="--h:@percent%"><b>@day.Day.ToLocalTime().ToString("dd/MM", culture)</b></span>
                    }
                </div>
            </article>

            <article class="manager-card">
                <div class="card-head"><div><p class="eyebrow">Best sellers</p><h3>Sản phẩm bán chạy</h3></div></div>
                @if (topSanPhams.Any())
                {
                    <div class="space-y-4">
                        @{ var rank = 1; }
                        @foreach (var item in topSanPhams)
                        {
                            <div class="rank-row"><span>@rank.ToString("00")</span><div><strong>@item.Ten</strong><small>@item.SoLuong sản phẩm</small></div><b>@item.SoLuong</b></div>
                            rank++;
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact"><span>◇</span><h3>Chưa có dữ liệu bán chạy</h3><p>Khi có hóa đơn, danh sách sản phẩm bán chạy sẽ hiển thị tại đây.</p></div>
                }
            </article>
        </div>

        <div class="grid gap-5 xl:grid-cols-[minmax(0,1.25fr)_minmax(320px,.75fr)]">
            <article class="manager-card overflow-hidden">
                <div class="card-head"><div><p class="eyebrow">Orders</p><h3>Đơn hàng gần đây</h3></div><button class="btn-secondary" type="button" data-page-link="orders">Xem tất cả</button></div>
                <div class="table-wrap">
                    <table class="manager-table">
                        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Nhân viên</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thời gian</th></tr></thead>
                        <tbody>
                            @foreach (var order in donHangs.Take(5))
                            {
                                <tr><td>HD-@order.Id.ToString("0000")</td><td>@(order.KhachHang?.HoTen ?? "Khách lẻ")</td><td>@(order.NhanVien?.HoTen ?? "Chưa gán")</td><td>@Money(order.TongTien)</td><td><span class="badge @OrderBadge(order.TrangThai)">@OrderText(order.TrangThai)</span></td><td>@TimeText(order.NgayDat)</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!donHangs.Any())
                {
                    <div class="empty-state compact"><span>◇</span><h3>Chưa có hóa đơn</h3><p>Dữ liệu hóa đơn sẽ xuất hiện sau khi hệ thống phát sinh đơn hàng.</p></div>
                }
            </article>

            <div class="grid gap-5">
                <article class="manager-card">
                    <div class="card-head"><div><p class="eyebrow">Alert</p><h3>Cảnh báo tồn kho</h3></div></div>
                    <div class="space-y-3">
                        @foreach (var product in sanPhams.Where(p => p.TonKho <= p.MucCanNhapLai).Take(4))
                        {
                            <div class="alert-row @(product.TonKho <= 0 ? "danger" : "warning")"><span>!</span><p>@product.Ten còn @product.TonKho @product.DonVi</p></div>
                        }
                        @if (!sanPhams.Any(p => p.TonKho <= p.MucCanNhapLai))
                        {
                            <div class="alert-row info"><span>i</span><p>Không có sản phẩm dưới mức cần nhập lại.</p></div>
                        }
                    </div>
                </article>
                <article class="manager-card">
                    <div class="card-head"><div><p class="eyebrow">Promotion</p><h3>Khuyến mãi đang chạy</h3></div></div>
                    <div class="timeline">
                        @foreach (var promo in khuyenMais.Where(p => p.KichHoat && p.NgayBatDau <= DateTime.UtcNow && p.NgayKetThuc >= DateTime.UtcNow).Take(3))
                        {
                            <div><span></span><strong>@promo.Ten</strong><small>@promo.PhanTramGiam.ToString("0.##")% • @DateText(promo.NgayBatDau) - @DateText(promo.NgayKetThuc)</small></div>
                        }
                        @if (!khuyenMais.Any(p => p.KichHoat && p.NgayBatDau <= DateTime.UtcNow && p.NgayKetThuc >= DateTime.UtcNow))
                        {
                            <div><span></span><strong>Chưa có khuyến mãi</strong><small>Tạo chương trình khuyến mãi để hiển thị tại đây.</small></div>
                        }
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section id="products" class="manager-page hidden space-y-6" data-page="products">
        <div class="page-title-row"><div><p class="eyebrow">Products</p><h2>Quản lý sản phẩm</h2><small>Dữ liệu lấy từ bảng SanPhams.</small></div><button class="btn-primary" data-open-modal type="button">Thêm sản phẩm</button></div>
        @if (TempData["SanPhamMessage"] is string sanPhamMessage)
        {
            <div class="alert-row @(TempData["SanPhamMessageType"]?.ToString() == "danger" ? "danger" : "info")"><span>i</span><p>@sanPhamMessage</p></div>
        }
        <div class="filter-panel">
            <label><span>Tìm kiếm</span><input type="search" placeholder="Tên hoặc mã sản phẩm"></label>
            <label><span>Danh mục</span><select><option>Tất cả danh mục</option>@foreach (var category in danhMucs){<option>@category.Ten</option>}</select></label>
            <label><span>Tồn kho</span><select><option>Tất cả trạng thái</option><option>Còn hàng</option><option>Sắp hết</option><option>Hết hàng</option></select></label>
            <label><span>Khoảng giá</span><input type="text" placeholder="Nhập khoảng giá"></label>
        </div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap">
                <table class="manager-table">
                    <thead><tr><th>Ảnh</th><th>Mã SP</th><th>Tên sản phẩm</th><th>Danh mục</th><th>Giá bán</th><th>Tồn kho</th><th>Trạng thái</th><th>Hành động</th></tr></thead>
                    <tbody>
                        @foreach (var product in sanPhams)
                        {
                            <tr><td><span class="product-thumb">@product.Ten.FirstOrDefault()</span></td><td>@product.Ma</td><td>@product.Ten</td><td>@(product.DanhMuc?.Ten ?? "Chưa phân loại")</td><td>@Money(product.GiaBan)</td><td>@product.TonKho @product.DonVi</td><td><span class="badge @ProductBadge(product)">@ProductStatus(product)</span></td><td><button class="btn-icon" type="button">👁</button><button class="btn-icon" type="button">✎</button><button class="btn-icon danger" type="button">×</button></td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!sanPhams.Any())
            {
                <div class="empty-state compact"><span>□</span><h3>Chưa có sản phẩm</h3><p>Thêm sản phẩm đầu tiên để bắt đầu quản lý tồn kho.</p></div>
            }
            <div class="pagination-bar"><button type="button">‹</button><button class="active" type="button">1</button><button type="button">›</button></div>
        </article>
    </section>

    <section id="orders" class="manager-page hidden space-y-6" data-page="orders">
        <div class="page-title-row"><div><p class="eyebrow">Orders</p><h2>Quản lý đơn hàng</h2><small>Dữ liệu lấy từ bảng DonHangs và ChiTietDonHangs.</small></div><button class="btn-primary" data-open-panel type="button">Chi tiết hóa đơn</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng đơn hôm nay</p><strong>@soHoaDonHomNay</strong><small>Từ dữ liệu DonHangs</small></article>
            <article class="stat-card"><p>Đã thanh toán</p><strong>@donHangs.Count(o => o.TrangThai == "DaThanhToan")</strong><small>Trạng thái DaThanhToan</small></article>
            <article class="stat-card"><p>Đang xử lý</p><strong>@donHangs.Count(o => o.TrangThai == "DangXuLy")</strong><small>Trạng thái DangXuLy</small></article>
            <article class="stat-card"><p>Doanh thu đơn hàng</p><strong>@Money(donHangs.Sum(o => o.TongTien))</strong><small>Tổng toàn bộ hóa đơn</small></article>
        </div>
        <div class="filter-panel"><label><span>Mã đơn</span><input placeholder="Nhập mã hóa đơn"></label><label><span>Ngày tạo</span><input type="date"></label><label><span>Trạng thái</span><select><option>Tất cả</option><option>Đã thanh toán</option><option>Đang xử lý</option></select></label><label><span>Nhân viên</span><select><option>Tất cả nhân viên</option>@foreach (var staff in nhanViens){<option>@staff.HoTen</option>}</select></label></div>
        <article class="manager-card overflow-hidden">
            <div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Nhân viên</th><th>SL</th><th>Tổng tiền</th><th>Thanh toán</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var order in donHangs){<tr><td>HD-@order.Id.ToString("0000")</td><td>@(order.KhachHang?.HoTen ?? "Khách lẻ")</td><td>@(order.NhanVien?.HoTen ?? "Chưa gán")</td><td>@order.ChiTiet.Sum(i => i.SoLuong)</td><td>@Money(order.TongTien)</td><td>@order.PhuongThucThanhToan</td><td><span class="badge @OrderBadge(order.TrangThai)">@OrderText(order.TrangThai)</span></td><td><button class="btn-secondary" data-open-panel type="button">Xem</button></td></tr>}</tbody></table></div>
            @if (!donHangs.Any()){<div class="empty-state compact"><span>◇</span><h3>Chưa có đơn hàng</h3><p>Hóa đơn sẽ hiển thị tại đây khi được tạo.</p></div>}
        </article>
    </section>

    <section id="customers" class="manager-page hidden space-y-6" data-page="customers">
        <div class="page-title-row"><div><p class="eyebrow">Customers</p><h2>Quản lý khách hàng</h2><small>Dữ liệu lấy từ bảng KhachHangs.</small></div><button class="btn-secondary" type="button">Xuất danh sách</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="stat-card"><p>Tổng khách hàng</p><strong>@khachHangs.Count</strong><small>Tất cả hồ sơ</small></article><article class="stat-card"><p>Đang kích hoạt</p><strong>@khachHangKichHoat</strong><small>KichHoat = true</small></article><article class="stat-card"><p>Tổng điểm thưởng</p><strong>@khachHangs.Sum(c => c.DiemThuong)</strong><small>Từ DiemThuong</small></article><article class="stat-card"><p>Điểm trung bình</p><strong>@(khachHangs.Any() ? Math.Round(khachHangs.Average(c => c.DiemThuong), 0) : 0)</strong><small>Điểm/khách</small></article>
        </div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã KH</th><th>Tên khách hàng</th><th>SĐT</th><th>Email</th><th>Điểm thưởng</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var customer in khachHangs){<tr><td>KH-@customer.Id.ToString("0000")</td><td>@customer.HoTen</td><td>@(customer.DienThoai ?? "-")</td><td>@(customer.Email ?? "-")</td><td>@customer.DiemThuong</td><td><span class="badge @(customer.KichHoat ? "success" : "danger")">@(customer.KichHoat ? "Đang hoạt động" : "Ngừng")</span></td><td><button class="btn-secondary" type="button">Chi tiết</button></td></tr>}</tbody></table></div>@if (!khachHangs.Any()){<div class="empty-state compact"><span>○</span><h3>Chưa có khách hàng</h3><p>Dữ liệu khách hàng sẽ xuất hiện khi có hồ sơ trong hệ thống.</p></div>}</article>
    </section>

    <section id="staff" class="manager-page hidden space-y-6" data-page="staff">
        <div class="page-title-row"><div><p class="eyebrow">Staff</p><h2>Quản lý nhân viên</h2><small>Dữ liệu lấy từ bảng NhanViens.</small></div><button class="btn-primary" type="button">Phân quyền</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            @foreach (var staff in nhanViens.Take(4))
            {
                <article class="employee-card"><span>@staff.HoTen.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault()?.FirstOrDefault()</span><strong>@staff.HoTen</strong><small>@staff.ChucVu</small><em class="badge @(staff.KichHoat ? "success" : "danger")">@(staff.KichHoat ? "Đang hoạt động" : "Ngừng")</em></article>
            }
        </div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã NV</th><th>Họ tên</th><th>SĐT</th><th>Email</th><th>Vai trò</th><th>Lương</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var staff in nhanViens){<tr><td>NV-@staff.Id.ToString("0000")</td><td>@staff.HoTen</td><td>@(staff.DienThoai ?? "-")</td><td>@(staff.Email ?? "-")</td><td>@staff.ChucVu</td><td>@Money(staff.Luong)</td><td><span class="badge @(staff.KichHoat ? "success" : "danger")">@(staff.KichHoat ? "Đang hoạt động" : "Ngừng")</span></td><td><button class="btn-secondary" type="button">Sửa</button></td></tr>}</tbody></table></div>@if (!nhanViens.Any()){<div class="empty-state compact"><span>◎</span><h3>Chưa có nhân viên</h3><p>Thêm nhân viên để quản lý hồ sơ và phân quyền.</p></div>}</article>
    </section>

    <section id="promotions" class="manager-page hidden space-y-6" data-page="promotions">
        <div class="page-title-row"><div><p class="eyebrow">Promotions</p><h2>Quản lý khuyến mãi</h2><small>Dữ liệu lấy từ bảng KhuyenMais.</small></div><button class="btn-primary" type="button">Tạo khuyến mãi</button></div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4"><article class="stat-card"><p>Đang chạy</p><strong>@khuyenMaiDangChay</strong><small>KichHoat = true</small></article><article class="stat-card"><p>Sắp hết hạn</p><strong>@khuyenMaiSapHetHan</strong><small>Trong 7 ngày</small></article><article class="stat-card"><p>Đã kết thúc</p><strong>@khuyenMaiDaKetThuc</strong><small>Qua ngày kết thúc</small></article><article class="stat-card"><p>Tổng chương trình</p><strong>@khuyenMais.Count</strong><small>Tất cả khuyến mãi</small></article></div>
        <div class="grid gap-4 lg:grid-cols-3">@foreach (var promo in khuyenMais.Take(3)){<article class="promo-card"><span>KM-@promo.Id.ToString("0000")</span><h3>@promo.Ten</h3><p>@DateText(promo.NgayBatDau) - @DateText(promo.NgayKetThuc)</p><b>@PromoText(promo)</b></article>}</div>
        <article class="manager-card overflow-hidden"><div class="table-wrap"><table class="manager-table"><thead><tr><th>Mã KM</th><th>Tên chương trình</th><th>Giảm giá</th><th>Bắt đầu</th><th>Kết thúc</th><th>Trạng thái</th><th>Hành động</th></tr></thead><tbody>@foreach (var promo in khuyenMais){<tr><td>KM-@promo.Id.ToString("0000")</td><td>@promo.Ten</td><td>@promo.PhanTramGiam.ToString("0.##")%</td><td>@DateText(promo.NgayBatDau)</td><td>@DateText(promo.NgayKetThuc)</td><td><span class="badge @PromoBadge(promo)">@PromoText(promo)</span></td><td><button class="btn-secondary" type="button">Sửa</button></td></tr>}</tbody></table></div>@if (!khuyenMais.Any()){<div class="empty-state compact"><span>✦</span><h3>Chưa có khuyến mãi</h3><p>Tạo chương trình đầu tiên để bắt đầu quản lý ưu đãi.</p></div>}</article>
    </section>
</div>

<div id="productModal" class="modal-shell hidden" aria-hidden="true">
    <form class="modal-card" asp-controller="QuanLy" asp-action="CreateSanPham" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="NhaCungCapId" value="@(nhaCungCaps.FirstOrDefault()?.Id ?? 0)">
        <input type="hidden" name="MucCanNhapLai" value="10">
        <input type="hidden" name="DonVi" value="pcs">
        <div class="card-head"><div><p class="eyebrow">Product modal</p><h3>Thêm sản phẩm</h3></div><button class="btn-icon" data-close-modal type="button">×</button></div>
        <div class="modal-grid">
            <label><span>Tên sản phẩm</span><input placeholder="Nhập tên sản phẩm"></label><label><span>Mã sản phẩm</span><input placeholder="Nhập mã sản phẩm"></label>
            <label><span>Danh mục</span><select>@foreach (var category in danhMucs){<option>@category.Ten</option>}</select></label><label><span>Giá nhập</span><input placeholder="Nhập giá nhập"></label>
            <label><span>Giá bán</span><input placeholder="Nhập giá bán"></label><label><span>Số lượng</span><input placeholder="Nhập số lượng"></label>
            <label><span>Hạn sử dụng</span><input type="date"></label><label><span>Upload ảnh</span><input type="file"></label>
            <label class="md:col-span-2"><span>Mô tả</span><textarea rows="3" placeholder="Nhập mô tả sản phẩm"></textarea></label>
        </div>
        <div class="flex justify-end gap-3"><button class="btn-secondary" data-close-modal type="button">Hủy</button><button class="btn-primary" type="button">Lưu sản phẩm</button></div>
    </form>
</div>

<aside id="invoicePanel" class="slide-panel translate-x-full">
    @{ var latestOrder = donHangs.FirstOrDefault(); }
    <div class="card-head"><div><p class="eyebrow">Invoice</p><h3>@(latestOrder == null ? "Chi tiết hóa đơn" : $"Chi tiết hóa đơn HD-{latestOrder.Id:0000}")</h3></div><button class="btn-icon" data-close-panel type="button">×</button></div>
    @if (latestOrder == null)
    {
        <div class="empty-state compact"><span>◇</span><h3>Chưa có hóa đơn</h3><p>Không có dữ liệu hóa đơn để hiển thị.</p></div>
    }
    else
    {
        <div class="space-y-4">
            <div class="alert-row info"><span>i</span><p>@OrderText(latestOrder.TrangThai), phương thức @latestOrder.PhuongThucThanhToan.</p></div>
            <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/70"><strong>@latestOrder.ChiTiet.Sum(i => i.SoLuong) sản phẩm</strong><p class="mb-0 mt-2 text-sm text-slate-500 dark:text-slate-400">@string.Join(", ", latestOrder.ChiTiet.Select(i => i.SanPham?.Ten).Where(name => !string.IsNullOrWhiteSpace(name)))</p></div>
            <div class="flex items-center justify-between border-t border-slate-200 pt-4 dark:border-slate-800"><span>Tổng tiền</span><strong class="text-2xl text-blue-600 dark:text-sky-300">@Money(latestOrder.TongTien)</strong></div>
            <button class="btn-primary w-full" type="button">Xuất PDF / In hóa đơn</button>
        </div>
    }
</aside>

@section Scripts {
    <script>
        (() => {
            const pages = document.querySelectorAll("[data-page]");
            const links = document.querySelectorAll("[data-page-link]");
            const modal = document.getElementById("productModal");
            const panel = document.getElementById("invoicePanel");
            const productForm = modal?.querySelector("form");
            const productFields = productForm?.querySelectorAll("input:not([type='hidden']), select, textarea") ?? [];
            const categoryIds = [@string.Join(",", danhMucs.Select(c => c.Id))];
            const fieldNames = ["Ten", "Ma", "DanhMucId", "GiaVon", "GiaBan", "TonKho", "", "", "MoTa"];

            productFields.forEach((field, index) => {
                if (fieldNames[index]) field.name = fieldNames[index];
            });

            const categorySelect = productFields[2];
            if (categorySelect) {
                Array.from(categorySelect.options).forEach((option, index) => {
                    if (categoryIds[index]) option.value = categoryIds[index];
                });
            }

            productForm?.querySelector(".btn-primary")?.setAttribute("type", "submit");

            const showPage = (pageName) => {
                pages.forEach(page => page.classList.toggle("hidden", page.dataset.page !== pageName));
                links.forEach(link => link.classList.toggle("is-active", link.dataset.pageLink === pageName));
                const target = document.getElementById(pageName);
                if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
            };

            links.forEach(link => link.addEventListener("click", (event) => {
                event.preventDefault();
                history.replaceState(null, "", `#${link.dataset.pageLink}`);
                showPage(link.dataset.pageLink);
            }));

            document.querySelectorAll("[data-open-modal]").forEach(btn => btn.addEventListener("click", () => modal?.classList.remove("hidden")));
            document.querySelectorAll("[data-close-modal]").forEach(btn => btn.addEventListener("click", () => modal?.classList.add("hidden")));
            modal?.addEventListener("click", event => { if (event.target === modal) modal.classList.add("hidden"); });

            document.querySelectorAll("[data-open-panel]").forEach(btn => btn.addEventListener("click", () => panel?.classList.remove("translate-x-full")));
            document.querySelectorAll("[data-close-panel]").forEach(btn => btn.addEventListener("click", () => panel?.classList.add("translate-x-full")));

            const syncPageFromHash = () => {
                const hash = location.hash.replace("#", "");
                if (hash && document.querySelector(`[data-page="${hash}"]`)) showPage(hash);
            };

            window.addEventListener("hashchange", syncPageFromHash);
            syncPageFromHash();
            setTimeout(syncPageFromHash, 0);
        })();

        setTimeout(() => {
            const pageName = location.hash.replace("#", "");
            if (!pageName) return;
            document.querySelectorAll("[data-page]").forEach(page => page.classList.toggle("hidden", page.dataset.page !== pageName));
            document.querySelectorAll("[data-page-link]").forEach(link => link.classList.toggle("is-active", link.dataset.pageLink === pageName));
        }, 50);
    </script>
}
