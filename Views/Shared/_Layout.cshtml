@using Microsoft.AspNetCore.Http
@inject WebQLministop.Data.ApplicationDbContext DbContext
@{
    var tenKhachHangDangNhap = Context.Session.GetString("KhachHangHoTen");
    var anhKhachHangDangNhap = Context.Session.GetString("KhachHangAnhDaiDien");
    var khachHangIdDangNhap = Context.Session.GetInt32("KhachHangId");
    var diemThuongSession = Context.Session.GetInt32("KhachHangDiemThuong");
    var diemThuongDangNhap = diemThuongSession ?? 0;
    if (khachHangIdDangNhap != null && diemThuongSession == null)
    {
        var diemTuDatabase = DbContext.KhachHangs
            .Where(k => k.Id == khachHangIdDangNhap.Value && k.KichHoat)
            .Select(k => (int?)k.DiemThuong)
            .FirstOrDefault();
        if (diemTuDatabase != null)
        {
            diemThuongDangNhap = diemTuDatabase.Value;
            Context.Session.SetInt32("KhachHangDiemThuong", diemThuongDangNhap);
        }
    }
    var chuCaiDaiDien = string.IsNullOrWhiteSpace(tenKhachHangDangNhap) ? "K" : tenKhachHangDangNhap.Trim()[0].ToString().ToUpper();
}
<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebQLministop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebQLministop.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            50: '#f0f9ff', 100: '#e0f2fe', 200: '#bae6fd',
                            300: '#7dd3fc', 400: '#38bdf8', 500: '#0ea5e9',
                            600: '#0284c7', 700: '#0369a1', 800: '#075985', 900: '#0c4a6e'
                        }
                    }
                }
            }
        };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        html.dark body {
            background: #0f172a;
            color: #e2e8f0;
        }
        html.dark .bg-white { background-color: #111827 !important; }
        html.dark .bg-white\/95 { background-color: rgba(17, 24, 39, 0.96) !important; }
        html.dark .bg-white\/10 { background-color: rgba(255, 255, 255, 0.12) !important; }
        html.dark .bg-slate-50,
        html.dark .bg-slate-100,
        html.dark .bg-slate-100\/50 { background-color: #1f2937 !important; }
        html.dark .hover\:bg-slate-50:hover,
        html.dark .hover\:bg-slate-100:hover,
        html.dark .hover\:bg-slate-200:hover {
            background-color: #243244 !important;
            color: #f8fafc !important;
        }
        html.dark .hover\:bg-red-50:hover {
            background-color: rgba(239, 68, 68, 0.18) !important;
        }
        html.dark .category-link:hover {
            background-color: #1e3a5f !important;
            color: #e0f2fe !important;
        }
        html.dark .category-link.bg-brand-50 {
            background-color: #0c4a6e !important;
            color: #f0f9ff !important;
        }
        html.dark .bg-brand-50,
        html.dark .bg-sky-50,
        html.dark .bg-sky-50\/70 { background-color: rgba(2, 132, 199, 0.16) !important; }
        html.dark .bg-emerald-50 { background-color: rgba(16, 185, 129, 0.14) !important; }
        html.dark .bg-red-50 { background-color: rgba(239, 68, 68, 0.14) !important; }
        html.dark .border-slate-100,
        html.dark .border-slate-200,
        html.dark .border-slate-200\/50,
        html.dark .border-sky-100,
        html.dark .border-sky-200,
        html.dark .border-brand-100 { border-color: #334155 !important; }
        html.dark .text-slate-900,
        html.dark .text-slate-800,
        html.dark .text-slate-700,
        html.dark .text-slate-600 { color: #f8fafc !important; }
        html.dark .text-slate-500,
        html.dark .text-slate-400,
        html.dark .text-slate-300 { color: #cbd5e1 !important; }
        html.dark .text-blue-700,
        html.dark .text-brand-600 { color: #7dd3fc !important; }
        html.dark .text-emerald-600,
        html.dark .text-emerald-700 { color: #6ee7b7 !important; }
        html.dark .text-red-500,
        html.dark .text-red-700 { color: #fca5a5 !important; }
        html.dark input,
        html.dark textarea,
        html.dark select {
            background-color: #0f172a !important;
            color: #f8fafc !important;
            border-color: #334155 !important;
        }
        html.dark input::placeholder {
            color: #94a3b8 !important;
        }
        html.dark .shadow-sm,
        html.dark .shadow-xl,
        html.dark .shadow-2xl {
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.35) !important;
        }
    </style>
    <script>
        (() => {
            const savedTheme = localStorage.getItem('ministop-theme');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
</head>
<body class="bg-slate-50 text-slate-800 antialiased selection:bg-brand-500 selection:text-white flex flex-col min-h-screen">
    <header class="sticky top-0 z-50 w-full bg-white shadow-sm transition-all duration-300">
        <div class="border-b border-slate-200/50">
            <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 gap-4">
                <a href="/" class="flex items-center gap-2 group text-decoration-none flex-shrink-0">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white shadow-lg shadow-brand-500/30 transition-transform duration-300 group-hover:scale-105">
                        <span class="font-bold text-lg">M</span>
                    </div>
                    <span class="hidden sm:block text-xl font-black tracking-tight text-slate-900 group-hover:text-brand-600 transition-colors duration-300">MiniStop</span>
                </a>

                <div class="flex-1 max-w-2xl hidden md:block">
                    <form action="/Home/TimKiem" method="get" class="relative group flex items-center m-0">
                        <input type="search" name="keyword" value="@Context.Request.Query["keyword"]" class="block w-full py-2.5 pl-5 pr-12 text-sm text-slate-900 bg-slate-100/50 border border-slate-200 rounded-l-full focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 focus:bg-white transition-all outline-none" placeholder="Tìm đồ uống, bánh kẹo, mì gói..." />
                        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-5 py-2.5 rounded-r-full transition-colors border border-brand-600 hover:border-brand-700" aria-label="Tìm kiếm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </button>
                    </form>
                </div>

                <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
                    <a href="/Home/TimKiem" class="md:hidden p-2 text-slate-500 hover:text-brand-600 transition-colors text-decoration-none" aria-label="Tìm kiếm">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </a>

                    <a href="/GioHang" class="relative p-2 text-slate-500 hover:text-brand-600 transition-colors text-decoration-none" aria-label="Giỏ hàng">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        <span id="cartCount" class="absolute -right-1 -top-1 hidden min-w-5 rounded-full bg-red-500 px-1.5 py-0.5 text-center text-[10px] font-bold leading-none text-white">0</span>
                    </a>

                    <button type="button" id="themeToggle" class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition hover:border-brand-300 hover:text-brand-600" aria-label="Đổi giao diện sáng tối" aria-pressed="false">
                        <svg class="h-5 w-5 theme-icon-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.36 6.36-.7-.7M6.34 6.34l-.7-.7m12.02 0-.7.7M6.34 17.66l-.7.7M12 8a4 4 0 100 8 4 4 0 000-8z"></path></svg>
                        <svg class="hidden h-5 w-5 theme-icon-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.8A8.5 8.5 0 1111.2 3a6.5 6.5 0 009.8 9.8z"></path></svg>
                    </button>

                    <div class="relative ml-2 border-l border-slate-200 pl-4">
                        @if (!string.IsNullOrWhiteSpace(tenKhachHangDangNhap))
                        {
                            <div class="relative" data-account-menu>
                                <button type="button" class="flex items-center gap-2 rounded-full bg-slate-100 py-1 pl-1 pr-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-200 border-0" data-account-menu-button aria-expanded="false" aria-haspopup="true">
                                    @if (!string.IsNullOrWhiteSpace(anhKhachHangDangNhap))
                                    {
                                        <img src="@anhKhachHangDangNhap" alt="@tenKhachHangDangNhap" class="h-8 w-8 rounded-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">@chuCaiDaiDien</span>
                                    }
                                    <span class="hidden max-w-32 truncate sm:inline">@tenKhachHangDangNhap</span>
                                    <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>

                                <div class="invisible absolute right-0 top-full z-50 mt-2 w-56 rounded-xl border border-slate-100 bg-white p-2 opacity-0 shadow-xl transition" data-account-menu-panel>
                                    <div class="mb-2 rounded-lg border border-brand-100 bg-brand-50 px-3 py-2">
                                        <div class="text-xs font-semibold text-brand-600">Điểm tích lũy</div>
                                        <div class="mt-1 text-lg font-black text-slate-900">@diemThuongDangNhap.ToString("N0") điểm</div>
                                        <div class="text-[11px] font-medium text-slate-500">1 điểm = 1đ giảm</div>
                                    </div>
                                    <a href="/TaiKhoan" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-brand-600 text-decoration-none">
                                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-50 text-brand-600">i</span>
                                        Thông tin cá nhân
                                    </a>
                                    <a href="/GioHang" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-brand-600 text-decoration-none">
                                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-600">G</span>
                                        Giỏ hàng
                                    </a>
                                    <a href="/TaiKhoan/LichSuDonHang" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-brand-600 text-decoration-none">
                                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600">L</span>
                                        Lịch sử mua hàng
                                    </a>
                                    <form method="post" action="/DangNhap/DangXuat" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-left text-sm font-semibold text-red-500 hover:bg-red-50 border-0 bg-transparent">
                                            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-50 text-red-500">X</span>
                                            Đăng xuất
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center gap-3">
                                <a href="/DangNhap" class="hidden sm:inline-flex items-center text-sm font-semibold text-slate-600 hover:text-brand-600 text-decoration-none">Đăng nhập</a>
                                <a href="/DangKy" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-600 shadow-sm transition-colors hover:bg-slate-200 hover:text-brand-600 text-decoration-none" aria-label="Đăng ký">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (ViewData["HideCategories"] as bool? != true)
        {
            <div class="bg-white border-b border-slate-100">
                <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                    <nav class="flex items-center gap-2 overflow-x-auto hide-scrollbar py-2" aria-label="Danh mục nhanh">
                        <a href="/" class="category-link rounded-full bg-brand-50 px-4 py-2 text-sm font-bold text-brand-700 whitespace-nowrap text-decoration-none">Trang chủ</a>
                        <a href="/Home/TimKiem?danhMuc=Do%20uong" class="category-link rounded-full px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-brand-700 whitespace-nowrap text-decoration-none transition-colors">Đồ uống</a>
                        <a href="/Home/TimKiem?danhMuc=Banh%20keo" class="category-link rounded-full px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-brand-700 whitespace-nowrap text-decoration-none transition-colors">Bánh kẹo</a>
                        <a href="/Home/TimKiem?danhMuc=Thuc%20pham" class="category-link rounded-full px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-brand-700 whitespace-nowrap text-decoration-none transition-colors">Thực phẩm</a>
                        <a href="/Home/TimKiem?danhMuc=Gia%20dung" class="category-link rounded-full px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-brand-700 whitespace-nowrap text-decoration-none transition-colors">Gia dụng</a>
                        <a href="/Home/TimKiem?sapXep=gia-tang" class="category-link rounded-full px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-brand-700 whitespace-nowrap text-decoration-none transition-colors">Giá tốt</a>
                    </nav>
                </div>
            </div>
        }
    </header>

    <main role="main" class="flex-1 w-full mx-auto pb-12">
        <form id="ajaxAntiForgeryForm" class="hidden">
            @Html.AntiForgeryToken()
        </form>
        @RenderBody()
    </main>

    <footer class="mt-auto border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="font-bold text-brand-600">MiniStop</span>
                <span class="text-sm text-slate-500">&copy; 2026 Đã đăng ký bản quyền.</span>
            </div>
            <div class="flex items-center gap-6 text-sm text-slate-500">
                <a href="#" class="hover:text-brand-600 transition-colors text-decoration-none">Về chúng tôi</a>
                <a href="#" class="hover:text-brand-600 transition-colors text-decoration-none">Chính sách</a>
                <a href="#" class="hover:text-brand-600 transition-colors text-decoration-none">Hỗ trợ (0909 123 456)</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
