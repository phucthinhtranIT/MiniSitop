@{
    Layout = "_Layout";
    ViewData["HideCategories"] = true;
    ViewData["Title"] = "Đăng ký";
    var form = Context.Request.HasFormContentType ? Context.Request.Form : null;
    var hoTen = form?["hoTen"].ToString() ?? string.Empty;
    var dienThoai = form?["dienThoai"].ToString() ?? string.Empty;
    var email = form?["email"].ToString() ?? string.Empty;
}

<section class="py-8 md:py-12">
    <div class="mx-auto grid max-w-6xl gap-8 rounded-[32px] border border-sky-100 bg-white/95 p-6 shadow-2xl shadow-sky-100 lg:grid-cols-[0.95fr_1.05fr] lg:p-10">
        <div class="rounded-[28px] bg-gradient-to-br from-blue-700 via-sky-700 to-slate-900 p-8 text-white shadow-xl lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-100">Tạo tài khoản</p>
            <h1 class="mt-4 text-3xl font-black md:text-4xl">Đăng ký thành viên để nhận ưu đãi mỗi ngày.</h1>
            <p class="mt-4 max-w-md text-sky-100/90">Mở khóa chương trình tích điểm, ưu đãi theo mùa và những khuyến mãi dành riêng cho khách hàng thân thiết.</p>
            <ul class="mt-6 space-y-3 text-sm text-sky-100/90">
                <li>Nhận mã giảm giá đầu tiên</li>
                <li>Theo dõi chương trình khuyến mãi</li>
                <li>Quản lý thông tin cá nhân nhanh chóng</li>
            </ul>
        </div>

        <div class="rounded-[28px] border border-sky-100 bg-sky-50/70 p-8 shadow-inner lg:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-blue-700">Trang đăng ký</p>
            <h2 class="mt-3 text-2xl font-bold text-slate-900">Tạo tài khoản mới</h2>
            <p class="mt-2 text-slate-600">Điền thông tin bên dưới để bắt đầu trải nghiệm.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
                    @Html.ValidationSummary(false, "", new { @class = "m-0 list-disc pl-4" })
                </div>
            }

            <form method="post" action="/DangKy" class="mt-8 space-y-4">
                @Html.AntiForgeryToken()
                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label for="hoTen" class="mb-1 block text-sm font-semibold text-slate-700">Họ và tên</label>
                        <input id="hoTen" name="hoTen" type="text" value="@hoTen" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="Nguyễn Văn A" autocomplete="name" />
                    </div>
                    <div>
                        <label for="dienThoai" class="mb-1 block text-sm font-semibold text-slate-700">Số điện thoại</label>
                        <input id="dienThoai" name="dienThoai" type="tel" value="@dienThoai" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="0909 123 456" autocomplete="tel" />
                    </div>
                </div>
                <div>
                    <label for="email" class="mb-1 block text-sm font-semibold text-slate-700">Email</label>
                    <input id="email" name="email" type="email" value="@email" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="example@ministop.vn" autocomplete="email" />
                </div>
                <div>
                    <label for="matKhau" class="mb-1 block text-sm font-semibold text-slate-700">Mật khẩu</label>
                    <input id="matKhau" name="matKhau" type="password" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                </div>
                <div>
                    <label for="xacNhanMatKhau" class="mb-1 block text-sm font-semibold text-slate-700">Xác nhận mật khẩu</label>
                    <input id="xacNhanMatKhau" name="xacNhanMatKhau" type="password" class="w-full rounded-2xl border border-sky-200 bg-white px-4 py-3 text-slate-800 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                </div>
                <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-blue-600 to-sky-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-100 transition hover:from-blue-700 hover:to-sky-600">Đăng ký tài khoản</button>
                <p class="text-center text-sm text-slate-600">Đã có tài khoản? <a href="/DangNhap" class="font-semibold text-blue-700 hover:text-blue-800">Đăng nhập</a></p>
            </form>
        </div>
    </div>
</section>
